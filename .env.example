# Copy this file to .env and fill in your model key.
# You can replace the model string with any LangChain tool-calling chat model.
OPENAI_API_KEY=your_key_here
LLM_MODEL=openai:gpt-4.1-mini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHUNK_SIZE=700
CHUNK_OVERLAP=120
TOP_K=4
PROMPT_COST_PER_1K=0.00050
COMPLETION_COST_PER_1K=0.00150
